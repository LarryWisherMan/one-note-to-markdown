            </one:OEChildren>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:16.0pt;font-weight:bold">
            <one:T><![CDATA[API Reference]]></one:T>
            <one:OEChildren>
              <one:OE style="font-family:Segoe UI;font-size:13.0pt;font-weight:bold">
                <one:T><![CDATA[ImportService]]></one:T>
                <one:OEChildren>
                  <one:OE>
                    <one:T><![CDATA[The <span style='font-family:Consolas;font-size:9pt'>ImportService</span> class orchestrates the import flow.]]></one:T>
                  </one:OE>
                  <one:OE>
                    <one:Table bordersVisible="true">
                      <one:Columns>
                        <one:Column index="0" width="600" />
                      </one:Columns>
                      <one:Row>
                        <one:Cell>
                          <one:OEChildren>
                            <one:OE>
                              <one:T><![CDATA[<span style='font-family:Consolas;font-size:9pt'>var service = new ImportService(oneNoteService, converter);<br/>var result = await service.ImportAsync(options, progress, token);</span>]]></one:T>
                            </one:OE>
                          </one:OEChildren>
                        </one:Cell>
                      </one:Row>
                    </one:Table>
                  </one:OE>
                </one:OEChildren>
              </one:OE>
              <one:OE style="font-family:Segoe UI;font-size:13.0pt;font-weight:bold">
                <one:T><![CDATA[MarkdownToOneNoteXmlConverter]]></one:T>
                <one:OEChildren>
                  <one:OE>
                    <one:T><![CDATA[Converts Markdown to OneNote page XML.]]></one:T>
                  </one:OE>
                  <one:OE>
                    <one:List>
                      <one:Bullet bullet="2" fontSize="11.0" />
                    </one:List>
                    <one:T><![CDATA[Input: Markdown string]]></one:T>
                  </one:OE>
                  <one:OE>
                    <one:List>
                      <one:Bullet bullet="2" fontSize="11.0" />
                    </one:List>
                    <one:T><![CDATA[Output: OneNote XML string]]></one:T>
                  </one:OE>
                  <one:OE>
                    <one:List>
                      <one:Bullet bullet="2" fontSize="11.0" />
                    </one:List>
                    <one:T><![CDATA[Supports: headings, lists, tables, code blocks, images]]></one:T>
                  </one:OE>
                </one:OEChildren>
              </one:OE>
            </one:OEChildren>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:16.0pt;font-weight:bold">
            <one:T><![CDATA[Troubleshooting]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:T><![CDATA[<i>If OneNote is not responding, try restarting the desktop app.</i>]]></one:T>
              </one:OE>
              <one:OE>
                <one:T><![CDATA[Common issues:]]></one:T>
              </one:OE>
              <one:OE>
                <one:List>
                  <one:Number numberSequence="0" numberFormat="##." fontSize="11.0" font="Segoe UI" />
                </one:List>
                <one:T><![CDATA[<b>COM error</b> - OneNote must be running]]></one:T>
              </one:OE>
              <one:OE>
                <one:List>
                  <one:Number numberSequence="0" numberFormat="##." fontSize="11.0" font="Segoe UI" />
                </one:List>
                <one:T><![CDATA[<b>Section not found</b> - Check notebook/section names are correct]]></one:T>
              </one:OE>
              <one:OE>
                <one:List>
                  <one:Number numberSequence="0" numberFormat="##." fontSize="11.0" font="Segoe UI" />
                </one:List>
                <one:T><![CDATA[<b>DLP blocked</b> - This tool bypasses DLP by using <span style='font-family:Consolas;font-size:9pt'>GetPageContent</span> directly]]></one:T>
              </one:OE>
            </one:OEChildren>
          </one:OE>
        </one:OEChildren>
