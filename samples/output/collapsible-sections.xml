        <one:OEChildren>
          <one:OE>
            <one:T><![CDATA[This is the top-level introduction. Everything below should nest under its heading.]]></one:T>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:16.0pt;font-weight:bold">
            <one:T><![CDATA[Getting Started]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:T><![CDATA[Follow these steps to set up the project.]]></one:T>
              </one:OE>
              <one:OE>
                <one:List>
                  <one:Number numberSequence="0" numberFormat="##." fontSize="11.0" font="Segoe UI" />
                </one:List>
                <one:T><![CDATA[Clone the repository]]></one:T>
              </one:OE>
              <one:OE>
                <one:List>
                  <one:Number numberSequence="0" numberFormat="##." fontSize="11.0" font="Segoe UI" />
                </one:List>
                <one:T><![CDATA[Run <span style='font-family:Consolas;font-size:9pt'>dotnet restore</span>]]></one:T>
              </one:OE>
              <one:OE>
                <one:List>
                  <one:Number numberSequence="0" numberFormat="##." fontSize="11.0" font="Segoe UI" />
                </one:List>
                <one:T><![CDATA[Run <span style='font-family:Consolas;font-size:9pt'>dotnet build</span>]]></one:T>
              </one:OE>
              <one:OE style="font-family:Segoe UI;font-size:13.0pt;font-weight:bold">
                <one:T><![CDATA[Prerequisites]]></one:T>
                <one:OEChildren>
                  <one:OE>
                    <one:List>
                      <one:Bullet bullet="2" fontSize="11.0" />
                    </one:List>
                    <one:T><![CDATA[.NET 10.0 SDK]]></one:T>
                  </one:OE>
                  <one:OE>
                    <one:List>
                      <one:Bullet bullet="2" fontSize="11.0" />
                    </one:List>
                    <one:T><![CDATA[Windows 10 or 11]]></one:T>
                  </one:OE>
                  <one:OE>
                    <one:List>
                      <one:Bullet bullet="2" fontSize="11.0" />
                    </one:List>
                    <one:T><![CDATA[OneNote desktop app]]></one:T>
                  </one:OE>
                </one:OEChildren>
              </one:OE>
              <one:OE style="font-family:Segoe UI;font-size:13.0pt;font-weight:bold">
                <one:T><![CDATA[Configuration]]></one:T>
                <one:OEChildren>
                  <one:OE>
                    <one:T><![CDATA[No configuration needed for basic usage. The defaults are:]]></one:T>
                  </one:OE>
