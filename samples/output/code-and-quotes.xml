  </one:Title>
  <one:Outline>
    <one:OEChildren>
      <one:OE style="font-family:Segoe UI;font-size:11.0pt">
        <one:T style="font-family:Segoe UI;font-size:20.0pt"><![CDATA[<span style='font-weight:bold'>Code Blocks and Quotes</span>]]></one:T>
        <one:OEChildren>
          <one:OE style="font-family:Segoe UI;font-size:11.0pt">
            <one:T style="font-family:Segoe UI;font-size:16.0pt"><![CDATA[<span style='font-weight:bold'>Inline Code</span>]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:T><![CDATA[Use the <span style='font-family:Consolas;font-size:9pt'>dotnet build</span> command to compile.]]></one:T>
              </one:OE>
            </one:OEChildren>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:11.0pt">
            <one:T style="font-family:Segoe UI;font-size:16.0pt"><![CDATA[<span style='font-weight:bold'>Fenced Code Block</span>]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:Table bordersVisible="true">
                  <one:Columns>
                    <one:Column index="0" width="600" />
                  </one:Columns>
                  <one:Row>
                    <one:Cell>
                      <one:OEChildren>
                        <one:OE>
                          <one:T><![CDATA[<span style='font-family:Consolas;font-size:9pt'>public class HelloWorld<br/>{<br/>    public static void Main(string[] args)<br/>    {<br/>        Console.WriteLine(&quot;Hello, OneNote!&quot;);<br/>    }<br/>}</span>]]></one:T>
                        </one:OE>
                      </one:OEChildren>
                    </one:Cell>
                  </one:Row>
                </one:Table>
              </one:OE>
            </one:OEChildren>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:11.0pt">
            <one:T style="font-family:Segoe UI;font-size:16.0pt"><![CDATA[<span style='font-weight:bold'>Another Code Block</span>]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:Table bordersVisible="true">
                  <one:Columns>
                    <one:Column index="0" width="600" />
                  </one:Columns>
                  <one:Row>
                    <one:Cell>
                      <one:OEChildren>
                        <one:OE>
                          <one:T><![CDATA[<span style='font-family:Consolas;font-size:9pt'>{<br/>  &quot;name&quot;: &quot;test&quot;,<br/>  &quot;version&quot;: &quot;1.0.0&quot;,<br/>  &quot;scripts&quot;: {<br/>    &quot;build&quot;: &quot;dotnet publish&quot;<br/>  }<br/>}</span>]]></one:T>
                        </one:OE>
                      </one:OEChildren>
                    </one:Cell>
                  </one:Row>
                </one:Table>
              </one:OE>
            </one:OEChildren>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:11.0pt">
            <one:T style="font-family:Segoe UI;font-size:16.0pt"><![CDATA[<span style='font-weight:bold'>Blockquotes</span>]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:T><![CDATA[<i>This is a quoted paragraph. It should render as indented italic text in OneNote.</i>]]></one:T>
              </one:OE>
              <one:OE>
                <one:T><![CDATA[<i>Another quote with <b>bold</b> inside it.</i>]]></one:T>
              </one:OE>
            </one:OEChildren>
          </one:OE>
          <one:OE style="font-family:Segoe UI;font-size:11.0pt">
            <one:T style="font-family:Segoe UI;font-size:16.0pt"><![CDATA[<span style='font-weight:bold'>Horizontal Rule</span>]]></one:T>
            <one:OEChildren>
              <one:OE>
                <one:T><![CDATA[Content above the rule.]]></one:T>
              </one:OE>
              <one:OE>
                <one:T><![CDATA[---]]></one:T>
              </one:OE>
              <one:OE>
                <one:T><![CDATA[Content below the rule.]]></one:T>
              </one:OE>
            </one:OEChildren>
          </one:OE>
        </one:OEChildren>
